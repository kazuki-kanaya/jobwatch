aws_region  = "ap-northeast-1"
aws_profile = "default"

# Set for custom domain mode. Leave null to use default Cognito domain.
cognito_custom_domain_name = "auth.obsern.dev"
cognito_domain_prefix      = "obsern-app"

terraform_state_bucket  = "obsern-terraform-state-prod"
terraform_state_region  = "ap-northeast-1"
terraform_state_profile = "default"

---
import type { LandingMessages } from "../../i18n/messages";

type Props = {
  messages: LandingMessages;
  dashboardUrl: string;
  docsHref: string;
};

const { messages, dashboardUrl, docsHref } = Astro.props;
---

<section id="docs" class="mx-auto w-full max-w-6xl px-4 py-16 md:px-8 md:py-20">
  <div class="rounded-3xl border border-cyan-400/20 bg-gradient-to-br from-cyan-400/20 via-blue-400/10 to-rose-400/10 px-6 py-12 text-center shadow-[0_20px_60px_rgba(6,78,120,0.25)] md:px-10">
    <h3 class="text-3xl font-bold text-white md:text-4xl">{messages.cta.title}</h3>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-8 text-slate-200">{messages.cta.subtitle}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={dashboardUrl} class="inline-flex h-11 items-center rounded-md bg-cyan-400 px-7 text-slate-950 hover:bg-cyan-300">{messages.cta.primary}</a>
      <a href={docsHref} class="inline-flex h-11 items-center rounded-md border border-slate-600 bg-slate-900/60 px-7 text-slate-100 hover:bg-slate-800">{messages.cta.secondary}</a>
    </div>
  </div>
</section>

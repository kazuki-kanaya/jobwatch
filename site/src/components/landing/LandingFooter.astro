---
import { Icon } from "astro-icon/components";
import type { LandingMessages } from "../../i18n/messages";

type Props = {
  messages: LandingMessages;
  githubUrl: string;
};

const { messages, githubUrl } = Astro.props;
---

<footer class="border-t border-[#1f2c3a] bg-[#0a1220] py-12">
  <div class="mx-auto w-full max-w-7xl px-4 md:px-8">
    <div class="flex flex-col items-start justify-between gap-5 rounded-2xl border border-cyan-400/20 bg-[#10192b] p-6 md:flex-row md:items-center">
      <div class="space-y-2">
        <p class="text-lg font-semibold text-white md:text-xl">{messages.footer.title}</p>
        <p class="text-sm leading-7 text-slate-300 md:text-base">{messages.footer.subtitle}</p>
      </div>
      <a href={githubUrl} target="_blank" rel="noreferrer" class="inline-flex h-11 items-center rounded-md bg-cyan-400 px-6 text-slate-950 hover:bg-cyan-300 md:shrink-0">
        <Icon name="github" class="mr-2 size-4" />
        {messages.footer.button}
      </a>
    </div>
  </div>
</footer>

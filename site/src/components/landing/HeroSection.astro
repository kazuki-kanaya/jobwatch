---
import type { LandingLocale, LandingMessages } from "../../i18n/messages";
import CopyButton from "./CopyButton.astro";

type Props = {
  locale: LandingLocale;
  messages: LandingMessages;
  dashboardUrl: string;
  docsHref: string;
  curlCommand: string;
};

const { locale, messages, dashboardUrl, docsHref, curlCommand } = Astro.props;

const quickStartText =
  locale === "ja"
    ? {
        run: "# 通常の実行",
        setup: "# 一度だけ初期化 (generate jobwatch.yaml)",
        wrap: "# jobwatch でラップして実行",
      }
    : {
        run: "# Run your training script normally",
        setup: "# One-time setup (generate jobwatch.yaml)",
        wrap: "# Wrap it with jobwatch",
      };
---

<section id="hero" class="relative mx-auto w-full max-w-7xl space-y-10 overflow-hidden px-4 py-12 md:px-8 md:py-16">
  <div class="pointer-events-none absolute -left-10 top-6 h-72 w-72 rounded-full bg-blue-500/15 blur-3xl"></div>
  <div class="pointer-events-none absolute right-4 top-12 h-60 w-60 rounded-full bg-fuchsia-500/10 blur-3xl"></div>
  <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.85fr)] lg:items-start">
    <div class="mx-auto max-w-3xl text-left lg:mx-0">
      <p class="inline-flex rounded-full border border-blue-400/35 bg-blue-500/10 px-4 py-1.5 text-xs font-semibold tracking-wide text-blue-300">
        {messages.hero.releaseBadge}
      </p>
      <h1 class="mt-5 text-5xl leading-[1.15] font-bold tracking-tight text-white md:text-5xl lg:text-6xl">
        {messages.hero.titleLead}<br />
        <span class="bg-gradient-to-r from-blue-400 via-indigo-300 to-cyan-300 bg-clip-text text-transparent">{messages.hero.titleAccent}</span>{messages.hero.titleTail}
      </h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-300 md:text-lg">{messages.hero.subtitle}</p>
      <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center">
        <a href={dashboardUrl} class="inline-flex h-12 min-w-44 items-center justify-center rounded-md bg-blue-500 px-8 text-base font-semibold text-white shadow-[0_0_28px_rgba(59,130,246,0.35)] hover:bg-blue-400">
          {messages.nav.getStarted}
        </a>
        <a href={docsHref} class="inline-flex h-12 min-w-44 items-center justify-center rounded-md border border-[#365078] bg-[#141f33] px-8 text-base font-semibold text-slate-200 hover:bg-[#1a2940] hover:text-white">
          {messages.cta.secondary}
        </a>
      </div>
    </div>

    <div class="rounded-2xl border border-[#2a3748] bg-[#111a2b]/95 p-4 shadow-[0_0_48px_rgba(59,130,246,0.18)] md:p-5">
      <p class="mb-3 text-sm font-semibold text-slate-300">{messages.hero.installHeading}</p>
      <div class="rounded-xl border border-[#2a3748] bg-[#141b24]">
        <div class="flex items-center justify-between border-b border-[#2a3748] px-3 py-3">
          <div class="inline-flex rounded-md border border-[#2f3f52] bg-[#151f2b] px-4 py-1.5 text-sm font-semibold text-cyan-300">curl</div>
          <CopyButton text={curlCommand} copyLabel={messages.hero.copyLabel} copiedLabel={messages.hero.copiedLabel} />
        </div>
        <div class="px-4 py-4">
          <code class="block whitespace-normal break-all font-mono text-sm leading-7 text-slate-100 md:text-base">$ {curlCommand}</code>
        </div>
      </div>
      <div class="mt-4 rounded-xl border border-[#314760] bg-[#171d29] p-4 shadow-[0_0_24px_rgba(56,189,248,0.1)] md:p-5">
        <div class="mb-3 flex items-center gap-2">
          <span class="size-3 rounded-full bg-red-400"></span>
          <span class="size-3 rounded-full bg-yellow-400"></span>
          <span class="size-3 rounded-full bg-green-400"></span>
          <span class="ml-2 font-mono text-xs text-slate-500">user@machine:~</span>
        </div>
        <div class="space-y-2 font-mono text-sm text-slate-300 md:text-base">
          <p>{quickStartText.run}</p>
          <p class="text-slate-500 line-through">python train_model.py --epochs 100</p>
          <p>{quickStartText.setup}</p>
          <p class="text-amber-300"><span class="text-cyan-300">➜</span> jobwatch init</p>
          <p>{quickStartText.wrap}</p>
          <p><span class="text-cyan-300">➜</span> <span class="text-amber-300">jobwatch run</span> python train_model.py --epochs 100</p>
        </div>
      </div>
    </div>
  </div>
</section>

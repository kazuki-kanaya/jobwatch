---
import type { LandingMessages } from "../../i18n/messages";

type Props = {
  messages: LandingMessages;
};

const { messages } = Astro.props;
---

<section id="demo" class="mx-auto w-full max-w-7xl px-4 py-6 md:px-8 md:py-8">
  <div class="overflow-hidden rounded-[1.75rem] border border-[#233246] bg-[linear-gradient(180deg,rgba(10,18,32,0.92),rgba(7,14,26,0.98))] shadow-[0_28px_80px_rgba(2,6,23,0.36)]">
    <div class="grid gap-6 px-5 py-6 md:px-8 md:py-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center">
      <div class="max-w-2xl">
        <p class="text-xs font-bold tracking-[0.18em] text-cyan-300 uppercase">{messages.demo.eyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold leading-tight text-white md:text-4xl">{messages.demo.title}</h2>
        <p class="mt-4 text-base leading-8 text-slate-300 md:text-lg">{messages.demo.subtitle}</p>
      </div>
      <div class="relative overflow-hidden rounded-2xl border border-[#2a3d57] bg-[#0a1322] p-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]">
        <div class="pointer-events-none absolute inset-x-0 top-0 h-16 bg-gradient-to-b from-cyan-300/8 to-transparent"></div>
          <img
            src="/landing/demo.gif"
            alt={messages.demo.alt}
            width="1280"
            height="720"
            class="block h-auto w-full rounded-[1rem] border border-[#1f2c40] object-cover"
            loading="lazy"
            decoding="async"
            fetchpriority="low"
          />
      </div>
    </div>
  </div>
</section>

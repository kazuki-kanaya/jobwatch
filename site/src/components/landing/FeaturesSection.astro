---
import { Icon } from "astro-icon/components";
import type { LandingMessages } from "../../i18n/messages";

type Props = {
  messages: LandingMessages;
};

const { messages } = Astro.props;
---

<section id="features" class="mx-auto grid w-full max-w-7xl gap-8 px-4 py-16 md:grid-cols-2 md:px-8 md:py-20">
  <div class="rounded-2xl border border-[#243448] bg-[#0f1928]/75 p-6 md:p-8">
    <h2 class="text-3xl font-bold leading-tight text-white md:text-4xl">{messages.features.title}</h2>
    <ul class="mt-8 space-y-6">
      {messages.features.cards.map((card) => (
        <li class="rounded-xl border border-[#2d3d52] bg-[#121f31] p-4">
          <p class="flex items-center gap-2 text-lg font-semibold text-white">
            <Icon name="feature" class="size-4 text-cyan-300" />
            {card.title}
          </p>
          <p class="mt-2 text-sm leading-7 text-slate-300">{card.body}</p>
        </li>
      ))}
    </ul>
  </div>
  <div class="relative overflow-visible rounded-2xl border border-[#2d3948] bg-[#0f1726] p-3 shadow-[0_20px_40px_rgba(2,6,23,0.28)] md:p-4">
    <div class="overflow-hidden rounded-xl border border-[#223247] bg-[#0b1321] shadow-[0_12px_28px_rgba(2,6,23,0.32)]">
      <img alt="Jobwatch dashboard preview" src="/dashboard.png" class="h-full w-full object-contain object-center opacity-92" />
    </div>
    <div class="absolute bottom-8 left-4 z-[9] w-[48%] -rotate-[6deg] overflow-hidden rounded-2xl border border-rose-300/65 bg-white/94 shadow-[0_18px_34px_rgba(2,6,23,0.42)] backdrop-blur-sm md:bottom-10 md:left-8 md:w-[44%]">
      <img alt="Jobwatch slack failed notification preview" src="/slack_failed.png" class="h-full w-full object-contain object-center" />
    </div>
    <div class="absolute bottom-2 right-2 z-10 w-[56%] rotate-[6deg] overflow-hidden rounded-2xl border border-[#a7f3d0]/60 bg-white/96 shadow-[0_22px_40px_rgba(2,6,23,0.52)] backdrop-blur-sm md:bottom-4 md:right-4 md:w-[50%]">
      <img alt="Jobwatch slack success notification preview" src="/slack_success.png" class="h-full w-full object-contain object-center" />
    </div>
  </div>
</section>
